{
  "name": "miscite-zotero-connector",
  "type": "module",
  "version": "0.1.2",
  "description": "Two-way sync between miscite and Zotero",
  "author": "miscite",
  "homepage": "https://github.com/ma-ji/miscite-zotero-connector#readme",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ma-ji/miscite-zotero-connector.git"
  },
  "bugs": {
    "url": "https://github.com/ma-ji/miscite-zotero-connector/issues"
  },
  "config": {
    "addonName": "Miscite Connector",
    "addonID": "miscite-sync@miscite.review",
    "addonRef": "miscite-connector",
    "addonInstance": "MisciteConnector",
    "prefsPrefix": "extensions.miscite-connector"
  },
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "release": "zotero-plugin release",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@zotero-plugin/eslint-config": "^0.6.7",
    "eslint": "^10.0.3",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
