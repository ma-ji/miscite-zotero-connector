# Path to Zotero binary
ZOTERO_COMMAND=/path/to/zotero

# Path to dev profile (create with: zotero -p)
ZOTERO_PROFILE_PATH=/path/to/zotero-profile

# Optional: Zotero data directory
# ZOTERO_DATA_DIR=

# Platform-specific kill command
# Linux:
KILL_COMMAND=kill
# macOS:
# KILL_COMMAND=kill
# Windows:
# KILL_COMMAND=taskkill /F /IM zotero.exe
